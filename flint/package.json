{
	"name": "flint-plugin",
	"version": "1.0.8",
	"description": "Sync your Obsidian vault across devices using Firebase Storage with CRDT-based conflict resolution.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"deploy": "npm run build && node deploy.mjs",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "eslint .",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"release": "node release.mjs",
		"release:minor": "node release.mjs minor",
		"release:major": "node release.mjs major"
	},
	"keywords": [],
	"author": "Tiago Fabre, Andrew Mao",
	"license": "MIT",
	"devDependencies": {
		"@eslint/json": "^1.2.0",
		"@types/node": "^20.19.37",
		"@typescript-eslint/eslint-plugin": "5.29.0",
		"@typescript-eslint/parser": "5.29.0",
		"@typescript-eslint/utils": "^8.57.2",
		"esbuild": "^0.27.0",
		"eslint": "^9.39.4",
		"eslint-plugin-obsidianmd": "^0.1.9",
		"obsidian": "latest",
		"tslib": "2.4.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.2",
		"vitest": "^1.6.1"
	},
	"dependencies": {
		"@automerge/automerge": "^2.0.0",
		"firebase": "^11.0.0"
	}
}
